generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  DIRECTOR
  REGIONAL_MANAGER
  SUPERVISOR
  STAFF
  ADMIN
}

enum PeriodType {
  MONTHLY
  WEEKLY_REF
}

enum ReviewStatus {
  DRAFT
  PUBLISHED
}

model User {
  id              String   @id @default(cuid())
  feishuUserId    String   @unique @map("feishu_user_id")
  feishuOpenId    String   @unique @map("feishu_open_id")
  name            String
  role            Role
  regionId        String?  @map("region_id")
  storeId         String?  @map("store_id")
  supervisorId    String?  @map("supervisor_id")
  avatarUrl       String?  @map("avatar_url")
  profilePhotoUrl String?  @map("profile_photo_url")
  joinedAt        DateTime @map("joined_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  region            Region?          @relation("RegionUsers", fields: [regionId], references: [id])
  store             Store?           @relation("StoreUsers", fields: [storeId], references: [id])
  supervisor        User?            @relation("SupervisorStaff", fields: [supervisorId], references: [id])
  staff             User[]           @relation("SupervisorStaff")
  managedRegion     Region?          @relation("RegionManager")
  supervisedStores  Store[]          @relation("StoreSupervisor")
  assignedTargets   Target[]         @relation("TargetAssignee")
  givenTargets      Target[]         @relation("TargetAssigner")
  dailyReports      DailyReport[]
  weeklyReviews     WeeklyReview[]
  championPhotos    ChampionPhoto[]  @relation("ChampionUser")
  uploadedPhotos    ChampionPhoto[]  @relation("PhotoUploader")
  pushedExperiences ExperiencePost[]
  notificationLogs  NotificationLog[]

  @@map("users")
}

model Region {
  id        String   @id @default(cuid())
  name      String
  managerId String?  @unique @map("manager_id")
  createdAt DateTime @default(now()) @map("created_at")

  manager User?   @relation("RegionManager", fields: [managerId], references: [id])
  stores  Store[]
  users   User[]  @relation("RegionUsers")

  @@map("regions")
}

model Store {
  id           String   @id @default(cuid())
  name         String
  regionId     String   @map("region_id")
  supervisorId String?  @map("supervisor_id")
  createdAt    DateTime @default(now()) @map("created_at")

  region       Region        @relation(fields: [regionId], references: [id])
  supervisor   User?         @relation("StoreSupervisor", fields: [supervisorId], references: [id])
  users        User[]        @relation("StoreUsers")
  targets      Target[]
  dailyReports DailyReport[]

  @@map("stores")
}

model Target {
  id          String     @id @default(cuid())
  assigneeId  String     @map("assignee_id")
  storeId     String?    @map("store_id")
  assignerId  String     @map("assigner_id")
  periodType  PeriodType @map("period_type")
  periodStart DateTime   @map("period_start") @db.Date
  periodEnd   DateTime   @map("period_end") @db.Date
  amount      Decimal    @db.Decimal(12, 2)
  isArchived  Boolean    @default(false) @map("is_archived")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  assignee User   @relation("TargetAssignee", fields: [assigneeId], references: [id])
  assigner User   @relation("TargetAssigner", fields: [assignerId], references: [id])
  store    Store? @relation(fields: [storeId], references: [id])

  @@map("targets")
}

model DailyReport {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  storeId        String   @map("store_id")
  reportDate     DateTime @map("report_date") @db.Date
  actualAmount   Decimal  @map("actual_amount") @db.Decimal(12, 2)
  isAchieved     Boolean  @map("is_achieved")
  failureReason  String?  @map("failure_reason")
  successSummary String?  @map("success_summary")
  isLate         Boolean  @default(false) @map("is_late")
  submittedAt    DateTime @map("submitted_at")
  createdAt      DateTime @default(now()) @map("created_at")

  user            User             @relation(fields: [userId], references: [id])
  store           Store            @relation(fields: [storeId], references: [id])
  experiencePosts ExperiencePost[]

  @@unique([userId, reportDate])
  @@map("daily_reports")
}

model WeeklyReview {
  id              String       @id @default(cuid())
  supervisorId    String       @map("supervisor_id")
  weekStart       DateTime     @map("week_start") @db.Date
  weekEnd         DateTime     @map("week_end") @db.Date
  aiContent       String       @map("ai_content")
  editedContent   String?      @map("edited_content")
  status          ReviewStatus @default(DRAFT)
  lastPublishedAt DateTime?    @map("last_published_at")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  supervisor User @relation(fields: [supervisorId], references: [id])

  @@unique([supervisorId, weekStart])
  @@map("weekly_reviews")
}

model ExperiencePost {
  id             String   @id @default(cuid())
  sourceReportId String?  @map("source_report_id")
  pushedBy       String   @map("pushed_by")
  content        String
  authorName     String   @map("author_name")
  storeName      String   @map("store_name")
  createdAt      DateTime @default(now()) @map("created_at")

  sourceReport DailyReport? @relation(fields: [sourceReportId], references: [id])
  pusher       User         @relation(fields: [pushedBy], references: [id])

  @@map("experience_posts")
}

model ChampionPhoto {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  weekStart  DateTime @map("week_start") @db.Date
  photoUrl   String   @map("photo_url")
  uploadedBy String   @map("uploaded_by")
  createdAt  DateTime @default(now()) @map("created_at")

  user     User @relation("ChampionUser", fields: [userId], references: [id])
  uploader User @relation("PhotoUploader", fields: [uploadedBy], references: [id])

  @@map("champion_photos")
}

model NotificationLog {
  id              String   @id @default(cuid())
  eventType       String   @map("event_type")
  recipientId     String   @map("recipient_id")
  feishuMessageId String?  @map("feishu_message_id")
  sentAt          DateTime @map("sent_at")
  payload         Json

  recipient User @relation(fields: [recipientId], references: [id])

  @@map("notification_logs")
}
